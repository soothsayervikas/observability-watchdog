# Production profile — copy to .env for deployment-style runs
APP_ENV=production
SECURITY_PROFILE=strict
LOG_LEVEL=INFO

DATABASE_URL=sqlite:///./data/watchdog.db

# Required for production API access (send as X-API-Key header / VITE_API_KEY in dashboard)
API_KEY=replace-with-strong-random-api-key

ANALYSIS_LOOKBACK_HOURS=24

WEBHOOK_URL=https://your-alerting-endpoint/webhook
WEBHOOK_HMAC_SECRET=replace-with-strong-random-secret
WEBHOOK_RETRY_BASE_SECONDS=1.0

DETECTION_ERROR_LEVELS=ERROR,FATAL
LOG_INGEST_CHUNK_SIZE=500
JSON_LOGGING=true
REDIS_URL=

LOG_MAX_UPLOAD_MB=10
LOG_MAX_RAW_BODY_MB=10
LOG_MAX_MESSAGE_CHARS=8192

RATE_LIMIT_ENABLED=true
RATE_LIMIT_INGEST_PER_MINUTE=120
RATE_LIMIT_ANALYZE_PER_MINUTE=10

CORS_ORIGINS=https://your-dashboard.example.com

# Azure OpenAI (optional — enables hybrid AI detection)
AI_CLASSIFIER_ENABLED=true
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
