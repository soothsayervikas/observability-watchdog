# Copy to .env.local and fill in your Azure OpenAI credentials.
# .env.local is gitignored and overrides values in .env.
#
#   copy .env.local.example .env.local
#
# IMPORTANT: Rotate your Azure OpenAI key if it was ever pasted in chat,
# committed to git, or shared in a screenshot.

AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
