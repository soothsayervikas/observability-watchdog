# =============================================================================
# Environment profiles
# =============================================================================
# APP_ENV=local       → relaxed: demo, docs, no rate limits, larger uploads, no API key
# APP_ENV=production  → strict: rate limits, payload caps, HMAC, API key required
#
# Override profile explicitly (optional):
# SECURITY_PROFILE=auto     follow APP_ENV (default)
# SECURITY_PROFILE=relaxed  always relaxed
# SECURITY_PROFILE=strict   always strict (even on local)

APP_NAME=observability-watchdog
APP_ENV=local
SECURITY_PROFILE=auto
LOG_LEVEL=INFO

# Database (SQLite default — swap to Postgres in production)
DATABASE_URL=sqlite:///./data/watchdog.db

# API authentication (required when APP_ENV=production and API_KEY is set)
# Local/relaxed: leave empty — no auth required
API_KEY=

# Analysis
ANALYSIS_LOOKBACK_HOURS=24

# Detection
DETECTION_WINDOW_MINUTES=5
DETECTION_BASELINE_BUCKETS=12
DETECTION_Z_THRESHOLD=2.5
DETECTION_MIN_ERROR_COUNT=5
DETECTION_PER_SERVICE=true
DETECTION_ERROR_LEVELS=ERROR,FATAL
DETECTION_MIN_ERROR_RATE=0.2
DETECTION_ZERO_BASELINE_RATE=0.2

# Webhook
WEBHOOK_URL=http://127.0.0.1:8765/webhook
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_BASE_SECONDS=1.0
# HMAC signing only applied when APP_ENV=production (or SECURITY_PROFILE=strict)
WEBHOOK_HMAC_SECRET=change-me-in-production

# Azure OpenAI — put real credentials in .env.local (gitignored), not here
#   copy .env.local.example .env.local
AI_CLASSIFIER_ENABLED=true
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_TIMEOUT_SECONDS=30
AI_MIN_CONFIDENCE=0.6
AI_MAX_LOG_SAMPLES=25

# Log sources (production-style ingestion)
LOG_WATCH_DIR=./data/incoming
LOG_PROCESSED_DIR=./data/incoming/processed
LOG_FAILED_DIR=./data/incoming/failed
LOG_DEFAULT_SERVICE=app-service

# Payload limits (enforced only in production / strict profile)
LOG_MAX_UPLOAD_MB=10
LOG_MAX_RAW_BODY_MB=10
LOG_MAX_MESSAGE_CHARS=8192
LOG_MAX_EVENTS_PER_FILE=50000
LOG_MAX_JSONL_LINES=100000
LOG_INGEST_CHUNK_SIZE=500
# Prune logs older than N days on startup and after ingest (0 = disabled)
LOG_RETENTION_DAYS=30
AI_CACHE_TTL_SECONDS=300

# Optional Redis for distributed rate limiting (pip install -e ".[redis]")
REDIS_URL=

# Only honor X-Forwarded-For when behind a trusted reverse proxy
TRUSTED_PROXY=false

# Serve built dashboard from dashboard/dist (Docker sets SERVE_DASHBOARD=true)
SERVE_DASHBOARD=false

# JSON structured logging (default: true)
JSON_LOGGING=true

# Rate limiting (production / strict profile only)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_INGEST_PER_MINUTE=120
RATE_LIMIT_ANALYZE_PER_MINUTE=10
RATE_LIMIT_DEFAULT_PER_MINUTE=300

# CORS (dashboard dev server)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
